{
  "$schema": "https://raw.githubusercontent.com/LuaLS/vscode-lua/master/setting/schema.json",
  "diagnostics": {
    "enable": true
  },
  "runtime": {
    "version": "LuaJIT",
    "path": [
      "lua/?.lua",
      "lua/?/init.lua"
    ]
  },
  "workspace": {
    "checkThirdParty": false,
    "ignoreDir": [
      "**/undo/",
      ".direnv"
    ],
    "ignoreGlobs": [
      "**/*_spec.lua"
    ],
    "library": [
      "$VIMRUNTIME",
      "$XDG_DATA_HOME/nvim/site/pack/core/opt/blink.cmp",
      "$XDG_DATA_HOME/nvim/site/pack/core/opt/fzf-lua",
      "$XDG_DATA_HOME/nvim/site/pack/core/opt/mason.nvim",
      "$XDG_DATA_HOME/nvim/site/pack/core/opt/mise.nvim",
      "$XDG_DATA_HOME/nvim/site/pack/core/opt/project.nvim",
      "$XDG_DATA_HOME/nvim/site/pack/core/opt/bufferline.nvim",
      "$XDG_DATA_HOME/nvim/site/pack/core/opt/gitlinker.nvim",
      "$XDG_DATA_HOME/nvim/site/pack/core/opt/mini.files",
      "$XDG_DATA_HOME/nvim/site/pack/core/opt/mini.notify",
      "$XDG_DATA_HOME/nvim/site/pack/core/opt/neoscroll.nvim",
      "$XDG_DATA_HOME/nvim/site/pack/core/opt/tokyonight.nvim",
      "$XDG_DATA_HOME/nvim/site/pack/core/opt/conform.nvim",
      "$XDG_DATA_HOME/nvim/site/pack/core/opt/lualine.nvim",
      "$XDG_DATA_HOME/nvim/site/pack/core/opt/mini.icons",
      "$XDG_DATA_HOME/nvim/site/pack/core/opt/nvim-lspconfig",
      "$XDG_DATA_HOME/nvim/site/pack/core/opt/vim-fugitive",
      "$XDG_DATA_HOME/nvim/site/pack/core/opt/diffview.nvim",
      "$XDG_DATA_HOME/nvim/site/pack/core/opt/mason-lspconfig.nvim",
      "$XDG_DATA_HOME/nvim/site/pack/core/opt/mini.pick",
      "$XDG_DATA_HOME/nvim/site/pack/core/opt/oil.nvim",
      "$XDG_DATA_HOME/nvim/site/pack/core/opt/which-key.nvim"
    ]
  },
  "diagnostics.disable": [
    "undefined-field",
    "param-type-mismatch"
  ],
  "completion.autoRequire": false
}
